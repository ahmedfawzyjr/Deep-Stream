          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "expr": "100 - ((1 - (sum(rate(gin_request_status_count{status!~\"5..\"}[30d])) / sum(rate(gin_request_status_count[30d])))) / 0.0002 * 100)",
