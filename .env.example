# ==============================================================================
# DeepStream - Environment Configuration Template
# ==============================================================================

# Database Connection (PostgreSQL)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/deepstream?sslmode=disable

# API Server Configuration
PORT=8080
JWT_SECRET=super-secret-change-me-in-production

# Inference Service Configuration (Rust gRPC Server)
INFERENCE_ADDR=localhost:50051

# ML Model Paths
MODEL_PATH=models/match_predictor_v1.onnx
FEATURE_NAMES_PATH=models/feature_names.json

# Observability Configuration
PROMETHEUS_PORT=2112
GRAFANA_PORT=3000
