# DeepStream Environment Variables Configuration

# PostgreSQL database connection URL
DATABASE_URL=postgres://postgres:postgres@localhost:5432/deepstream?sslmode=disable

# Address of the Rust inference gRPC engine
INFERENCE_ADDR=localhost:50051

# Secret key used for signing JWT authentication tokens
JWT_SECRET=super-secret-jwt-key-change-in-production

# Path to the exported ONNX model used by the Rust inference engine
MODEL_PATH=../models/match_predictor_v1.onnx

# Port on which the Go API server will run
API_PORT=8080

# Environment mode (development, staging, production)
ENV=development
